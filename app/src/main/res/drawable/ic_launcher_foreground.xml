        android:fillColor="#FFFFFFFF"
        android:pathData="M47,30 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0 z" />

    <!-- bottom-left node -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M27,74 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0 z" />

    <!-- bottom-right node -->
